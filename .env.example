# ---- Startboard environment (copy to .env / .env.dev and fill in) ----

# App
APP_ENV=development                 # development | production | testing
SECRET_KEY=change-me-to-a-long-random-string
TZ=Australia/Adelaide

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8002

# Database (raw sqlite file)
STARTBOARD_DB_PATH=/data/startboard.db
STARTBOARD_DATA_HOST_PATH=./.data

# Sessions / cookies
SESSION_TTL_DAYS=30
SESSION_COOKIE_SECURE=false          # true in production (HTTPS via Traefik)
SESSION_COOKIE_DOMAIN=               # leave blank unless sharing across subdomains

# CORS (dev only; in prod the SPA is same-origin so this is unused)
FRONTEND_URL=http://localhost:5173
FRONTEND_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=120
RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_PER_MINUTE=10       # stricter limit for /auth/login

# Favicons
FAVICON_DIR=/data/icons
FAVICON_FALLBACK_PROVIDER=https://www.google.com/s2/favicons?sz=64&domain=
ICONIFY_API_BASE_URL=https://api.iconify.design
ICON_UPLOAD_MAX_SVG_BYTES=262144
ICON_UPLOAD_MAX_ICO_BYTES=524288
ICON_UPLOAD_MAX_PNG_BYTES=1048576
ICON_UPLOAD_MAX_WEBP_BYTES=1048576
ICON_UPLOAD_MAX_JPG_BYTES=1048576
ICON_UPLOAD_MAX_GIF_BYTES=1048576

# Managed background images
MANAGED_IMAGES_DIR=/data/managed-images
MANAGED_VARIANTS_DIR=/data/managed-variants
MANAGED_IMAGE_IMPORT_DIR=/data/imports
MANAGED_IMAGE_MAX_UPLOAD_BYTES=104857600

# Homepage compose-label import
HOMEPAGE_COMPOSE_PATH=/imports/dockerconfigs/docker-compose.yml
HOMEPAGE_COMPOSE_ENV_PATH=/imports/dockerconfigs/.env

# Logging
LOG_LEVEL=INFO
LOG_TIMEZONE=Australia/Adelaide
LOG_DIR=/data/logs
LOG_FILE_ENABLED=true

# ---- Deploy (compose / Traefik) ----
STARTBOARD_HOST=start.batserver.au
DOMAIN_PRIMARY=batserver.au
TAG=latest

# ---- Frontend build args (Vite) ----
VITE_API_BASE_URL=/api
VITE_APP_VERSION=dev
VITE_ICON_UPLOAD_MAX_SVG_BYTES=262144
VITE_ICON_UPLOAD_MAX_ICO_BYTES=524288
VITE_ICON_UPLOAD_MAX_PNG_BYTES=1048576
VITE_ICON_UPLOAD_MAX_WEBP_BYTES=1048576
VITE_ICON_UPLOAD_MAX_JPG_BYTES=1048576
VITE_ICON_UPLOAD_MAX_GIF_BYTES=1048576
